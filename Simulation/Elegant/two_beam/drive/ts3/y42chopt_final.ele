!	name = "QIMP13",
!	upper_limit = 10,
!&end

!&optimization_variable
!	item = "K1",
!	lower_limit = -10,
!	name = "QIMP14",
!	upper_limit = 10,
!&end

&optimization_variable
	item = "K1",
	lower_limit = -20,
	name = "QIMP15",
	upper_limit = 20,
&end

&optimization_variable
	item = "K1",
	lower_limit = -20,
	name = "QIMP16",
	upper_limit = 20,
&end

&optimization_variable
	item = "K1",
	lower_limit = -20,
	name = "QIMP17",
	upper_limit = 20,
&end

&optimization_variable
	item = "K1",
	lower_limit = -20,
	name = "QIMP18",
	upper_limit = 20,
&end

&optimization_variable
	item = "K1",
	lower_limit = -20,
	name = "QIMP19",
	upper_limit = 20,
&end

&optimization_variable
	item = "K1",
	lower_limit = -20,
	name = "QIMP20",
	upper_limit = 20,
&end


&bunched_beam
&end

&optimize
	summarize_setup=1
&end

&save_lattice
	filename = "second.lte"
&end



!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
! check fit
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
&divide_elements
	name = *
	maximum_length = 0.01
&end

&run_setup
	lattice = "second.lte",
	use_beamline = "awa_beamline",
	default_order = 2,
	p_central = "{sddsanalyzebeam dist_1d.sdds -pipe=out |     sdds2stream -pipe -column=pAverage}",
	sigma = "%s.s",
	final = "%s.fin",
	output = "%s.out",
	magnets = "%s.mag",
	centroid = "%s.cen"
&end

&run_control
	n_indices = 0
&end

&twiss_output
        matched=0
      concat_order = 1,        ! for speed
        beta_x  = "{sddsanalyzebeam dist_1d.sdds -pipe=out | sdds2stream -pipe -column=betax}",
        beta_y  = "{sddsanalyzebeam dist_1d.sdds -pipe=out | sdds2stream -pipe -column=betay}",
        alpha_x = "{sddsanalyzebeam dist_1d.sdds -pipe=out | sdds2stream -pipe -column=alphax}",
        alpha_y = "{sddsanalyzebeam dist_1d.sdds -pipe=out | sdds2stream -pipe -column=alphay}",
	filename = "%s.twi"
&end

&floor_coordinates
	filename = "%s.survey"
	include_vertices = 1
	magnet_centers = 1
&end

&sdds_beam
	input = "dist_1d.sdds"
&end

&track
&end






























